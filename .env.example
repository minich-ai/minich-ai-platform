OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# JSON object mapping consumer ids to SHA-256 API-key hashes.
# Generate fakeclient1 and fakeclient2 with: npm run keys:generate
API_CONSUMER_KEY_HASHES=
METERING_ADMIN_KEY_HASH=

# Vercel's Upstash integration supplies the KV_* variables automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Default: 20 authorized chat requests per consumer per rolling minute.
RATE_LIMIT_REQUESTS_PER_MINUTE=20
